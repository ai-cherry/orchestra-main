# Example environment configuration for Orchestra
# Copy this file to .env and fill in your actual values

# Google Cloud Project
GOOGLE_CLOUD_PROJECT=cherry-ai-project
GCP_PROJECT_ID=cherry-ai-project

# API Keys
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-your-anthropic-api-key-here}
OPENAI_API_KEY=${OPENAI_API_KEY:-your-openai-api-key-here}
GOOGLE_API_KEY=${GOOGLE_API_KEY:-your-google-api-key-here}

# Redis/DragonflyDB Configuration
REDIS_URL=redis://localhost:6379
DRAGONFLY_HOST=localhost
DRAGONFLY_PORT=6379
DRAGONFLY_DB=0

# MCP Server Configuration
MCP_SERVER_HOST=0.0.0.0
MCP_SECRET_MANAGER_PORT=8002
MCP_FIRESTORE_PORT=8080
MCP_DRAGONFLY_PORT=8004
MCP_CLOUD_RUN_PORT=8001

# Logging
LOG_LEVEL=INFO

# Application Settings
APP_ENV=development
DEBUG=true